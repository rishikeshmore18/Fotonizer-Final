<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude sensitive data from backup -->
    <exclude domain="sharedpref" path="secure_prefs.xml"/>
    <exclude domain="database" path="photoapp10.db"/>
    <exclude domain="file" path="crash_reports/"/>
    <exclude domain="file" path="photos/"/>
    <exclude domain="file" path="thumbs/"/>
    
    <!-- Include only app preferences -->
    <include domain="sharedpref" path="app_preferences.xml"/>
</full-backup-content>