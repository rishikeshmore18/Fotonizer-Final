      {
        "name": "Google Drive Backup",
        "description": "Cloud backup and restore functionality using Google Drive API",
        "files": [
          "app/src/main/java/com/example/photoapp10/feature/backup/drive/DriveAppData.kt",
          "app/src/main/java/com/example/photoapp10/feature/backup/drive/DriveRestore.kt",
