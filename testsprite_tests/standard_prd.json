        "api_doc": {
          "openapi": "3.0.0",
          "info": {
            "title": "Google Drive Backup API",
            "version": "1.0.0",
            "description": "API for Google Drive backup and restore operations"
          },
          "paths": {
            "/backup": {
              "post": {
                "summary": "Create backup",
                "description": "Create a backup of all photos and albums to Google Drive",
                "responses": {
                  "200": {
                    "description": "Backup created successfully",
                    "content": {
                      "application/json": {
                        "schema": {
                          "type": "object",
                          "properties": {
                            "backupId": {
                              "type": "string"
                            },
                            "timestamp": {
                              "type": "integer"
                            },
                            "photosCount": {
                              "type": "integer"
                            },
                            "albumsCount": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "/restore": {
              "post": {
                "summary": "Restore from backup",
                "description": "Restore photos and albums from Google Drive backup",
                "responses": {
                  "200": {
                    "description": "Restore completed successfully",
                    "content": {
                      "application/json": {
                        "schema": {
                          "type": "object",
                          "properties": {
                            "photosRestored": {
                              "type": "integer"
                            },
                            "albumsRestored": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
